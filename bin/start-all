#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
BASE_DIR="${MAIL_MCP_BASE_DIR:-$HOME/.opcoach-mcp-mail}"
SERVER_REGISTRY_DIR="$BASE_DIR/servers"
BUILD_IF_MISSING=1
DRY_RUN=0

usage() {
  cat <<'USAGE'
Usage: bin/start-all [--dry-run] [--no-build]

Starts every local MCP mail server registered by bin/local-wizard.

Options:
  --dry-run   Print what would be started without starting servers.
  --no-build  Fail if target/opcoach-mcp-mail.jar does not exist.
  -h, --help  Show this help.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --no-build)
      BUILD_IF_MISSING=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

read_server_file() {
  local server_file="$1"
  PROFILE=""
  CONFIG_FILE=""
  RUN_DIR=""
  HOST="127.0.0.1"
  PORT=""

  local line key value
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" || "$line" == \#* || "$line" != *=* ]] && continue
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      PROFILE) PROFILE="$value" ;;
      CONFIG_FILE) CONFIG_FILE="$value" ;;
      RUN_DIR) RUN_DIR="$value" ;;
      HOST) HOST="$value" ;;
      PORT) PORT="$value" ;;
    esac
  done < "$server_file"
}

validate_server() {
  local server_file="$1"
  if [[ -z "$PROFILE" || -z "$CONFIG_FILE" || -z "$RUN_DIR" || -z "$HOST" || -z "$PORT" ]]; then
    echo "Invalid server registry file: $server_file" >&2
    return 1
  fi
  if [[ ! "$PORT" =~ ^[0-9]+$ ]] || (( PORT < 1 || PORT > 65535 )); then
    echo "Invalid port in $server_file: $PORT" >&2
    return 1
  fi
  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Missing configuration for profile $PROFILE: $CONFIG_FILE" >&2
    return 1
  fi
}

shopt -s nullglob
SERVER_FILES=("$SERVER_REGISTRY_DIR"/*.env)
shopt -u nullglob

if (( ${#SERVER_FILES[@]} == 0 )); then
  echo "No registered local MCP mail servers found in $SERVER_REGISTRY_DIR."
  echo "Run bin/local-wizard once per mailbox to register them."
  exit 0
fi

FAILURES=0
for server_file in "${SERVER_FILES[@]}"; do
  read_server_file "$server_file"
  if ! validate_server "$server_file"; then
    FAILURES=$((FAILURES + 1))
    continue
  fi

  echo "Starting profile $PROFILE on http://$HOST:$PORT/mcp"
  if [[ "$DRY_RUN" -eq 1 ]]; then
    continue
  fi

  ARGS=(--profile "$PROFILE" --host "$HOST" --port "$PORT")
  if [[ "$BUILD_IF_MISSING" -eq 0 ]]; then
    ARGS+=(--no-build)
  fi

  if ! env \
    MAIL_MCP_CONFIG="$CONFIG_FILE" \
    MAIL_MCP_RUN_DIR="$RUN_DIR" \
    "$REPO_DIR/bin/start-server" "${ARGS[@]}"; then
    FAILURES=$((FAILURES + 1))
  fi
done

if (( FAILURES > 0 )); then
  echo "$FAILURES server(s) could not be started." >&2
  exit 1
fi
