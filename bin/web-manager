#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd -- "$SCRIPT_DIR/.." && pwd)"
JAR="$REPO_DIR/target/opcoach-mcp-mail.jar"

source "$SCRIPT_DIR/java-runtime"

PORT="${MAIL_MCP_WEB_MANAGER_PORT:-18100}"
BUILD_IF_MISSING=1
NO_OPEN=0
START_REGISTERED=0

usage() {
  cat <<'USAGE'
Usage: bin/web-manager [--port PORT] [--no-build] [--no-open] [--start-registered]

Starts the MCP Mail Local Manager web UI on 127.0.0.1.
The web manager also hosts local MCP endpoints in the same Java process.

Options:
  --port PORT         Local manager port. Defaults to MAIL_MCP_WEB_MANAGER_PORT or 18100.
  --no-build          Fail if target/opcoach-mcp-mail.jar does not exist.
  --no-open           Print the URL without asking Java to open the browser.
  --start-registered  Start every registered MCP endpoint in this process.
  -h, --help          Show this help.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --port)
      [[ $# -ge 2 ]] || { echo "Missing value for --port" >&2; exit 2; }
      PORT="$2"
      shift 2
      ;;
    --no-build)
      BUILD_IF_MISSING=0
      shift
      ;;
    --no-open)
      NO_OPEN=1
      shift
      ;;
    --start-registered)
      START_REGISTERED=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ ! "$PORT" =~ ^[0-9]+$ ]] || (( PORT < 1 || PORT > 65535 )); then
  echo "Invalid web manager port: $PORT" >&2
  exit 2
fi

if [[ ! -f "$JAR" ]]; then
  if [[ "$BUILD_IF_MISSING" -eq 0 ]]; then
    echo "Missing jar: $JAR" >&2
    echo "Run ./mvnw -DskipTests package first." >&2
    exit 1
  fi
  mail_mcp_select_java
  echo "Using Java: $MAIL_MCP_JAVA"
  echo "Building $JAR ..."
  (cd "$REPO_DIR" && mail_mcp_with_java_env ./mvnw -DskipTests package)
fi

mail_mcp_select_java
JAVA_OPTS=(
  -Xms16m
  -Xmx192m
  -Xss512k
  -XX:+UseSerialGC
  -XX:ActiveProcessorCount=2
  -XX:ReservedCodeCacheSize=48m
)
EXTRA_JAVA_OPTS=()
if [[ -n "${MAIL_MCP_JAVA_OPTS:-}" ]]; then
  EXTRA_JAVA_OPTS=($MAIL_MCP_JAVA_OPTS)
fi
ARGS=(-cp "$JAR" org.opcoach.mailmcp.config.WebManagerApplication --port "$PORT")
if [[ "$NO_OPEN" -eq 1 ]]; then
  ARGS+=(--no-open)
fi
if [[ "$START_REGISTERED" -eq 1 ]]; then
  ARGS+=(--start-registered)
fi
COMMAND=("$MAIL_MCP_JAVA" "${JAVA_OPTS[@]}")
if (( ${#EXTRA_JAVA_OPTS[@]} > 0 )); then
  COMMAND+=("${EXTRA_JAVA_OPTS[@]}")
fi
COMMAND+=("${ARGS[@]}")
exec "${COMMAND[@]}"
