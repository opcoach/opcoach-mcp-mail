#!/usr/bin/env bash

MAIL_MCP_REQUIRED_JAVA="${MAIL_MCP_REQUIRED_JAVA:-24}"
MAIL_MCP_RUNTIME_DIR="${MAIL_MCP_RUNTIME_DIR:-$REPO_DIR/.runtime}"
MAIL_MCP_JRE_DIR="$MAIL_MCP_RUNTIME_DIR/temurin-jre-$MAIL_MCP_REQUIRED_JAVA"

mail_mcp_java_major() {
  local java_bin="$1"
  "$java_bin" -version 2>&1 | sed -nE 's/.*version "([0-9]+).*/\1/p' | head -n 1
}

mail_mcp_java_is_compatible() {
  local java_bin="$1"
  local major
  [[ -x "$java_bin" ]] || return 1
  major="$(mail_mcp_java_major "$java_bin" || true)"
  [[ -n "$major" ]] && (( major >= MAIL_MCP_REQUIRED_JAVA ))
}

mail_mcp_detect_platform() {
  local os arch
  case "$(uname -s)" in
    Darwin) os="mac" ;;
    Linux) os="linux" ;;
    *)
      echo "Unsupported operating system for automatic Java download: $(uname -s)" >&2
      return 1
      ;;
  esac

  case "$(uname -m)" in
    x86_64|amd64) arch="x64" ;;
    arm64|aarch64) arch="aarch64" ;;
    *)
      echo "Unsupported CPU architecture for automatic Java download: $(uname -m)" >&2
      return 1
      ;;
  esac

  printf '%s %s\n' "$os" "$arch"
}

mail_mcp_download() {
  local url="$1"
  local output="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fL --progress-bar "$url" -o "$output"
    return
  fi
  if command -v wget >/dev/null 2>&1; then
    wget -O "$output" "$url"
    return
  fi
  echo "curl or wget is required to download Java automatically." >&2
  return 1
}

mail_mcp_install_jre() {
  local os arch archive tmp_dir java_home java_bin
  read -r os arch < <(mail_mcp_detect_platform)

  if ! command -v tar >/dev/null 2>&1; then
    echo "tar is required to extract Java automatically." >&2
    return 1
  fi

  archive="$MAIL_MCP_RUNTIME_DIR/downloads/temurin-jre-$MAIL_MCP_REQUIRED_JAVA-$os-$arch.tar.gz"
  tmp_dir="$MAIL_MCP_RUNTIME_DIR/tmp/temurin-jre-$MAIL_MCP_REQUIRED_JAVA-$os-$arch"
  local url="https://api.adoptium.net/v3/binary/latest/$MAIL_MCP_REQUIRED_JAVA/ga/$os/$arch/jre/hotspot/normal/eclipse?project=jdk"

  mkdir -p "$(dirname "$archive")" "$tmp_dir" "$(dirname "$MAIL_MCP_JRE_DIR")"
  rm -rf "$tmp_dir" "$MAIL_MCP_JRE_DIR"
  mkdir -p "$tmp_dir"

  echo "Compatible Java $MAIL_MCP_REQUIRED_JAVA was not found. Downloading a local Eclipse Temurin JRE..."
  mail_mcp_download "$url" "$archive"
  tar -xzf "$archive" -C "$tmp_dir"

  java_bin="$(find "$tmp_dir" -path '*/bin/java' -type f -print -quit)"
  if [[ -z "$java_bin" ]]; then
    echo "Downloaded Java archive does not contain bin/java." >&2
    return 1
  fi

  java_home="$(cd -- "$(dirname -- "$java_bin")/.." && pwd)"
  mv "$java_home" "$MAIL_MCP_JRE_DIR"
  rm -rf "$tmp_dir"
}

mail_mcp_select_java() {
  if [[ -n "${MAIL_MCP_JAVA:-}" ]] && mail_mcp_java_is_compatible "$MAIL_MCP_JAVA"; then
    MAIL_MCP_JAVA_HOME="$(cd -- "$(dirname -- "$MAIL_MCP_JAVA")/.." && pwd)"
    export MAIL_MCP_JAVA MAIL_MCP_JAVA_HOME
    return 0
  fi

  if [[ -n "${JAVA_HOME:-}" ]] && mail_mcp_java_is_compatible "$JAVA_HOME/bin/java"; then
    MAIL_MCP_JAVA="$JAVA_HOME/bin/java"
    MAIL_MCP_JAVA_HOME="$JAVA_HOME"
    export MAIL_MCP_JAVA MAIL_MCP_JAVA_HOME
    return 0
  fi

  if command -v java >/dev/null 2>&1; then
    local system_java
    system_java="$(command -v java)"
    if mail_mcp_java_is_compatible "$system_java"; then
      MAIL_MCP_JAVA="$system_java"
      MAIL_MCP_JAVA_HOME="$(cd -- "$(dirname -- "$system_java")/.." && pwd)"
      export MAIL_MCP_JAVA MAIL_MCP_JAVA_HOME
      return 0
    fi
  fi

  if ! mail_mcp_java_is_compatible "$MAIL_MCP_JRE_DIR/bin/java"; then
    mail_mcp_install_jre
  fi

  MAIL_MCP_JAVA="$MAIL_MCP_JRE_DIR/bin/java"
  MAIL_MCP_JAVA_HOME="$MAIL_MCP_JRE_DIR"
  export MAIL_MCP_JAVA MAIL_MCP_JAVA_HOME
}

mail_mcp_with_java_env() {
  JAVA_HOME="$MAIL_MCP_JAVA_HOME" PATH="$MAIL_MCP_JAVA_HOME/bin:$PATH" "$@"
}
